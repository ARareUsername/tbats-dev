# TBATS Landing Page — Environment Variables
# Copy to `.env` and fill in real values. Never commit secrets.

# EmailJS (client-side fallback; prefer the serverless proxy for production)
VITE_EMAILJS_SERVICE_ID=service_tbats
VITE_EMAILJS_TEMPLATE_ID=template_tbats
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Server-side only (used by the /api/contact serverless function)
EMAILJS_SERVICE_ID=service_tbats
EMAILJS_TEMPLATE_ID=template_tbats
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key
